{
  "name": "tasktrace-mcp",
  "version": "1.7.0",
  "description": "TaskTrace MCP integration package for OpenClaw, Claude Code, and Cursor-compatible bundles.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "files": [
    ".codex-plugin",
    "assets",
    ".claude-plugin",
    ".cursor-plugin",
    ".agents",
    ".mcp.json",
    "plugins",
    "README.md",
    "scripts",
    "versionUpdate.mjs"
  ],
  "scripts": {
    "install:codex-local": "node ./scripts/install-codex-plugin.mjs",
    "pack": "bash scripts/clawhub-pack.sh \"$(node -p 'require(\"./package.json\").version')\"",
    "set-version": "node ./versionUpdate.mjs",
    "test": "node --test",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/release-notes-generator": "14.1.0",
    "conventional-changelog-conventionalcommits": "8.0.0",
    "semantic-release": "24.2.7"
  }
}
