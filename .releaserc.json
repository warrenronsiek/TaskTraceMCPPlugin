{
  "branches": [
    {
      "name": "master"
    },
    {
      "name": "dev",
      "prerelease": true
    }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          {
            "scope": "docs",
            "release": false
          },
          {
            "type": "feat",
            "release": "minor"
          },
          {
            "scope": "ci",
            "release": false
          },
          {
            "type": "ci",
            "release": false
          },
          {
            "type": "fix",
            "release": "minor"
          },
          {
            "scope": "build",
            "release": "patch"
          },
          {
            "type": "perf",
            "release": "patch"
          },
          {
            "type": "test",
            "release": false
          },
          {
            "scope": "test",
            "release": false
          },
          {
            "type": "refactor",
            "release": "patch"
          },
          {
            "scope": "no-release",
            "release": false
          }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node versionUpdate.mjs ${nextRelease.version} && mkdir -p dist && npm pack --pack-destination dist/"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "index.js", ".claude-plugin/plugin.json", ".cursor-plugin/plugin.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
  ]
}
